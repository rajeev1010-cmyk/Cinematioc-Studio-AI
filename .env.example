# Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client IDs
# Use the "Client ID" from your Google Cloud Console
VITE_GOOGLE_CLIENT_ID=

# Google Cloud Console -> APIs & Services -> Credentials -> API Keys
# You MUST create an "API Key" here if the one from Firebase doesn't work.
# Also, ensure "Google Picker API" is ENABLED in the API Library for this project.
VITE_GOOGLE_PICKER_API_KEY=

# Gemini API Key (handled by platform, but for local dev)
GEMINI_API_KEY=
